# ============================================================
# Jaga Eyang — Environment Variables Template
# ============================================================
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# cp .env.example .env
#
# PERINGATAN: Jangan pernah commit file .env ke GitHub!
# Pastikan .env ada di dalam .gitignore Anda.
# ============================================================

# ------------------------------------------------------------
# WAJIB — Amazon Nova API Key
# Dapatkan API key dari: https://nova.amazon.com
# ------------------------------------------------------------
NOVA_API_KEY=your_nova_api_key_here

# ------------------------------------------------------------
# OPSIONAL — Konfigurasi Tesseract OCR
# Hanya diperlukan di Windows. Linux/Mac biasanya otomatis.
# Contoh Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# ------------------------------------------------------------
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ------------------------------------------------------------
# OPSIONAL — Idempotency Key
# Mencegah double-billing jika request dikirim dua kali.
# Default: true. Set ke false hanya untuk debugging.
# ------------------------------------------------------------
USE_IDEMPOTENCY=true

# ------------------------------------------------------------
# OPSIONAL — Port Server
# Default: 8000. Ubah jika port 8000 sudah digunakan.
# ------------------------------------------------------------
PORT=8000
